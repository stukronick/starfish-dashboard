# SmartMCA Nexus API Configuration
# Get your API key from Settings → API Access in the SmartMCA platform

# Live key for production data
SMARTMCA_API_KEY=smca_live_YOUR_KEY_HERE

# API base URL
SMARTMCA_API_BASE=https://api.nexus.smartmca.com/api/public/v1

# Optional: Syndicator entity ID (for syndicator-bound keys, leave blank)
SYNDICATOR_ID=
